# Host UID/GID for docker compose — see docker-compose.yml's ``user:`` field.
# The Makefile exports these automatically; only set them here if you plan
# to run ``docker compose`` directly without going through ``make``.
#   HOST_UID=1000
#   HOST_GID=1000

DJANGO_SECRET_KEY=replace-me
DEBUG=True
REDIS_URL=redis://redis:6379/0

# SQLite job-state db, relative to the project root (the bind-mounted /app).
DATABASE_PATH=db.sqlite3

# ---------------------------------------------------------------------------
# Provider mode — `fake` (default) returns bundled fixture artifacts and
# never touches the network or spends money; `real` calls the cloud vendors.
# Flip a single stage live by setting `real` and supplying that vendor's key.
# ---------------------------------------------------------------------------
PROVIDER_MODE=fake

# Replicate (Demucs vocal separation, WhisperX caption alignment).
# The model refs default (in settings.py) to verified pinned versions; only set
# these to override with a different model/version.
REPLICATE_API_TOKEN=
REPLICATE_DEMUCS_MODEL=
REPLICATE_WHISPERX_MODEL=

# fal (FLUX still + portrait, image->video background loop).
FAL_KEY=
FAL_FLUX_MODEL=fal-ai/flux/dev
FAL_IMAGE_TO_VIDEO_MODEL=fal-ai/wan-i2v

# Lip-sync vendor — one of: hedra | sync | magic_hour.
LIPSYNC_PROVIDER=omnihuman
HEDRA_API_KEY=
SYNC_API_KEY=
MAGIC_HOUR_API_KEY=

# ---------------------------------------------------------------------------
# Telegram delivery — the finished mp4 is sent here for manual review/post.
# Create a bot via @BotFather; get your chat id from @userinfobot.
# ---------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Whether to render karaoke captions (align_captions stage). Set False to
# skip word-level alignment entirely and drop that Replicate call.
ENABLE_CAPTIONS=True
